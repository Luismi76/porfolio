        <div class="flex items-center justify-center mb-2"><Image src={estudio.imagen} alt="" class=" w-24"></div>
        <h3 class="font-extrabold">{estudio.nombre}</h3>
        <p class="opacity-65">{estudio.empresa}</p>
        <p class="font-boldmb-1">{estudio.horas} h</p>    
