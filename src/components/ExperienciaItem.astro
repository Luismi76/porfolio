---
interface Props {
  titulo: string;
  empresa: string;
  fechas: string;
  imagen?: string;
  descripcion: string;
}
const { titulo, empresa, imagen, fechas, descripcion } = Astro.props;
---

<li class="mb-10 ms-4">

  <div
    class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700"
  >
  </div>
  <div class="flex">
  <div class="size-20">
    <img src={imagen} alt="">
</div>
<div class="flex-auto">
  <time
    class="mb-1 text-sm font-normal leading-none text-cyan-400 dark:text-cyan-500"
    >{fechas}</time
  >
  <h3 class="text-lg font-semibold text-yellow-300 dark:text-white">{titulo}</h3>
</div>
</div>
  <p class="text-base font-normal text-gray-100 dark:text-gray-400 line-clamp-3 hover:line-clamp-none">
    {descripcion}
  </p>
</li>
